<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head", { title: "How to Build a $1M Digital Product Roadmap" }) %>
</head>
<body>
  <header class="nav">
    <div class="logo">Million Roadmap</div>
    <a href="#buy" class="primary-btn link-btn">Get the Book</a>
  </header>

  <main>
    <section class="hero">
      <div class="hero-text">
        <p class="badge">Digital product business guide</p>

        <h1>Learn how digital products can grow into a serious online business.</h1>

        <p class="subtitle">
          A practical ebook for beginners who want to create, launch, and sell digital products.
        </p>

        <a href="#buy" class="primary-btn link-btn">
          Get Instant Access for <%= price %>
        </a>

        <p class="small-note">Secure payment through PayPal.</p>
      </div>
    </section>

    <section class="pricing" id="buy">
      <h2>Get instant access</h2>

      <div class="price"><%= price %></div>

      <% if (!paypalClientId) { %>
        <p>Payment not ready yet</p>
      <% } else { %>
        <div id="paypal-button-container"></div>
      <% } %>

    </section>
  </main>

  <% if (paypalClientId) { %>
    <script src="https://www.paypal.com/sdk/js?client-id=<%= paypalClientId %>&currency=USD"></script>
    <script src="/js/paypal.js"></script>
  <% } %>

</body>
</html>
